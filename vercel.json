{
  "crons": [
    { "path": "/api/cron/slack-sync", "schedule": "*/30 * * * *" },
    { "path": "/api/cron/notifications", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/unanswered-questions", "schedule": "5,35 * * * *" },
    { "path": "/api/cron/scrape-links", "schedule": "0 6 * * *" }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/:username/:path*",
      "destination": "/api"
    },
    {
      "source": "/:username",
      "destination": "/api"
    },
    {
      "source": "/",
      "destination": "/api"
    }
  ]
}

